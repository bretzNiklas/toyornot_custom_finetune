AUTH_TOKEN=replace_with_a_long_random_token
HF_TOKEN=hf_token_with_access_to_the_private_model_repo
MODEL_REPO_ID=qwertzniki/graffiti-student-dinov2-base-224
MODEL_REVISION=main
MODEL_VERSION=student-v2-dinov2
MODEL_ROOT=/srv/graffiti-student/models
MODEL_DIR=/srv/graffiti-student/models/student-v2-dinov2
RUNTIME_ROOT=/srv/graffiti-student/runtime
JOBS_DB_PATH=/srv/graffiti-student/runtime/jobs.sqlite3
JOB_SPOOL_DIR=/srv/graffiti-student/runtime/spool
WORKER_CONCURRENCY=1
JOB_LEASE_SECONDS=30
MAX_RETRIES=2
MAX_ESTIMATED_WAIT_SECONDS=90
JOB_RETENTION_HOURS=24
WORKER_HEARTBEAT_TIMEOUT_SECONDS=45
WORKER_HEARTBEAT_INTERVAL_SECONDS=5
WORKER_IDLE_POLL_SECONDS=0.5
DEFAULT_PROCESSING_SECONDS=5.0
PROCESSING_AVERAGE_WINDOW=20
ORPHAN_PAYLOAD_GRACE_SECONDS=300
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
JUDGE_API_TOKEN=replace_with_the_same_or_rotated_api_token
JUDGE_API_BASE_URL=https://api.piecerate.me
JUDGE_API_TIMEOUT_MS=30000
SUPABASE_JUDGE_API_JOBS_TABLE=judge_api_jobs
SUPABASE_JUDGE_API_RESULTS_TABLE=judge_api_results
SUPABASE_JUDGE_API_INPUT_BUCKET=judge-api-inputs
JUDGED_IMAGE_ARCHIVE_DIR=/srv/graffiti-student/runtime/judged-images
WORKER_ID=niklasserver
JUDGE_JOB_LOCK_TIMEOUT_SECONDS=600
JUDGE_JOB_LOCK_REFRESH_SECONDS=120
JUDGE_JOB_POLL_WAIT_MS=8000
# Legacy knob. The event-driven handoff worker ignores this value and logs a warning if it is set.
JUDGE_JOB_IDLE_SLEEP_SECONDS=1
JUDGE_JOB_SAFETY_SWEEP_SECONDS=600
JUDGE_JOB_MAX_ATTEMPTS=5
JUDGE_JOB_BACKOFF_SCHEDULE_SECONDS=30,120,600,600
